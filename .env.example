# PayrollEngine Dokploy Configuration
# Copy to .env and customize

# Database password (alphanumeric only, no special chars)
DB_PASSWORD=PayrollStrongPass789

# WebApp external port (default: 8081)
WEBAPP_PORT=8081

# ASP.NET environment (Development | Production)
ASPNETCORE_ENVIRONMENT=Production

# SQL init script URL (default: main branch)
# Change to a specific tag/branch if needed:
# SQL_SOURCE_URL=https://raw.githubusercontent.com/Payroll-Engine/PayrollEngine.Backend/v0.9.0-beta.17/Database/ModelCreate.sql
SQL_SOURCE_URL=https://raw.githubusercontent.com/Payroll-Engine/PayrollEngine.Backend/main/Database/ModelCreate.sql
